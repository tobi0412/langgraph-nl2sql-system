# App
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL (DVD Rental)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dvdrental
DB_CONNECT_TIMEOUT=5

# LLM base config (for following iterations)
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
LLM_BASE_URL=https://sa-llmproxy.it.itba.edu.ar

# Feature flags
ENABLE_SCHEMA_AGENT=true
ENABLE_QUERY_AGENT=true

# Schema Agent (iteration 3)
SCHEMA_DOCS_PATH=data/schema_docs.json
SCHEMA_AGENT_MAX_ITERATIONS=15

# Streamlit UI (spec-ui style)
API_BASE_URL=http://localhost:8000
API_TIMEOUT=15
STREAM_DEFAULT=false

# LangSmith observability (LLM + LangGraph traces)
# Create API key: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langgraph-nl2sql-system
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
